{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "DatabaseType": "MSSQL",
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "FileStorage": {
    "MaxFileSizeMB": 20,
    "AllowedExtensions": [ ".pdf", ".docx", ".xlsx", ".png", ".jpg", ".jpeg", ".txt", ".zip", ".rar" ],
    "StorageMode": "Local",
    "Local": {
      "PhysicalPath": "C:\\FileHubStorage",
      "BaseUrl": "http://localhost:7191/files"
    },
    "Network": {
      "PhysicalPath": "\\\\192.168.100.20\\FileRepo",
      "BaseUrl": "http://192.168.100.20/FileRepo"
    }
  },
  "Jwt": {},
  "Ldap": {
    "Url": "localhost",
    "Port": 389,
    "UseSsl": false,
    "BindOn": "",
    "BindCredentials": "",
    "SearchFilter": "(&(objectClass=*)(sAMAccountName={0}))",
    "SearchBase": "DC=example,DC=com",
    "UIDAttribute": "objectGUID",
    "SAMAccountNameAttribute": "sAMAccountName",
    "DisplayNameAttribute": "CN",
    "EmailNameAttribute": "mail"
  },
  "AllowedHosts": "*"
}
