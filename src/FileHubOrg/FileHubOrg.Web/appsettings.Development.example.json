{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=FileHubOrg.Dev;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Secret": "DevelopmentJwtSecretChangeMe"
  },
  "Ldap": {
    "Url": "localhost",
    "SearchFilter": "(&(objectClass=*)(sAMAccountName={0}))",
    "SearchBase": "DC=example,DC=com",
    "BindOn": "CN=admin,OU=Users,DC=example,DC=com",
    "AdminCn": "Admins,OU=IT,DC=example,DC=com",
    "BindCredentials": "DevelopmentBindPassword",
    "UIDAttribute": "objectGUID",
    "SAMAccountNameAttribute": "sAMAccountName",
    "DisplayNameAttribute": "CN",
    "EmailNameAttribute": "mail"
  }
}
