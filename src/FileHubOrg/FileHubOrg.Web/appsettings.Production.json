{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "FileStorage": {
    "MaxFileSizeMB": 20,
    "AllowedExtensions": [ ".pdf", ".docx", ".xlsx", ".png", ".jpg", ".jpeg", ".txt", ".zip", ".rar" ],
    "StorageMode": "Local",
    "Local": {
      "PhysicalPath": "/app/storage",
      "BaseUrl": "http://localhost/files"
    },
    "Network": {
      "PhysicalPath": "\\\\network-share.example.com\\FileRepo",
      "BaseUrl": "http://network-share.example.com/FileRepo"
    }
  },
  "Jwt": {},
  "Ldap": {
    "SearchFilter": "(&(objectClass=*)(sAMAccountName={0}))",
    "SearchBase": "DC=example,DC=com",
    "UIDAttribute": "objectGUID",
    "SAMAccountNameAttribute": "sAMAccountName",
    "DisplayNameAttribute": "CN",
    "EmailNameAttribute": "mail"
  },
  "AllowedHosts": "*"
}
