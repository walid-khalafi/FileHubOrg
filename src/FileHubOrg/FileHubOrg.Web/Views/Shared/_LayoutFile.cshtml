@using Microsoft.AspNetCore.Identity
@using FileHubOrg.Domain.Entities.User
@inject FileHubOrg.Application.Interfaces.ILabelService labelService
@inject FileHubOrg.Application.Interfaces.IDepartmentService departmentService
@inject UserManager<ApplicationUser> UserManager

@{
    Layout = "_Layout";
    var user        = await UserManager.GetUserAsync(User);
    var userLabels  = await labelService.GetLabelsAsync(user!.Id);
    var departments = await departmentService.GetDepartmentsAsync();

    var currentId         = ViewContext.RouteData.Values["id"]?.ToString();
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
}

@section Styles {
<style>
    /* ── Layout shell ── */
    .file-layout {
        display: flex;
        gap: 1.25rem;
        align-items: flex-start;
        min-height: calc(100vh - 120px);
    }

    /* ── Sidebar ── */
    .file-sidebar {
        width: 240px;
        flex-shrink: 0;
        position: sticky;
        top: calc(60px + 1.5rem);   /* navbar height + page padding */
        max-height: calc(100vh - 100px);
        overflow-y: auto;
        scrollbar-width: thin;
        scrollbar-color: #dee2e6 transparent;
    }

    .file-sidebar::-webkit-scrollbar { width: 4px; }
    .file-sidebar::-webkit-scrollbar-thumb { background: #dee2e6; border-radius: 4px; }

    @@media (max-width: 991px) {
        .file-sidebar { display: none; }
        .file-main    { width: 100% !important; }
    }

    /* Sidebar section header */
    .sidebar-section-title {
        font-size: .68rem;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: #9ca3af;
        padding: .5rem .75rem .25rem;
        margin-bottom: .15rem;
    }

    /* Sidebar nav items */
    .sidebar-nav .sidebar-item {
        display: flex;
        align-items: center;
        gap: .55rem;
        padding: .42rem .75rem;
        border-radius: 7px;
        font-size: .875rem;
        color: #374151;
        text-decoration: none;
        transition: background .12s, color .12s;
        cursor: pointer;
    }

    .sidebar-nav .sidebar-item:hover {
        background: #f3f4f6;
        color: #111827;
    }

    .sidebar-nav .sidebar-item.active {
        background: #ede9fe;
        color: #4f46e5;
        font-weight: 600;
    }

    .sidebar-nav .sidebar-item .item-icon {
        width: 18px;
        text-align: center;
        flex-shrink: 0;
        font-size: .85rem;
    }

    .sidebar-nav .sidebar-item .item-badge {
        margin-left: auto;
        font-size: .65rem;
        background: #e5e7eb;
        color: #6b7280;
        border-radius: 20px;
        padding: 1px 7px;
        font-weight: 600;
    }

    .sidebar-nav .sidebar-item.active .item-badge {
        background: #c4b5fd;
        color: #4f46e5;
    }

    /* Sidebar divider */
    .sidebar-divider {
        border: none;
        border-top: 1px solid #f3f4f6;
        margin: .5rem .75rem;
    }

    /* ── Main content ── */
    .file-main {
        flex: 1;
        min-width: 0;
    }

    /* ── Mobile sidebar toggle ── */
    .sidebar-toggle-btn {
        display: none;
    }

    @@media (max-width: 991px) {
        .sidebar-toggle-btn { display: inline-flex; }
    }

    /* ── Off-canvas sidebar (mobile) ── */
    #mobileSidebar .offcanvas-header {
        border-bottom: 1px solid #f3f4f6;
        padding: 1rem 1.25rem;
    }

    #mobileSidebar .offcanvas-body { padding: .75rem; }

    /* ── Shared modal styles ── */
    .modal-content {
        border: none;
        border-radius: 12px;
        box-shadow: 0 20px 60px rgba(0,0,0,.15);
    }

    .modal-header { border-bottom: 1px solid #f3f4f6; }
    .modal-footer { border-top: 1px solid #f3f4f6; }
    .modal-footer .btn { border-radius: 20px; }

    /* ── Accordion (share modal) ── */
    .accordion-button { font-size: .9rem; padding: .65rem 1rem; }
    .accordion-body   { padding-left: 2.25rem !important; }
</style>

    @await RenderSectionAsync("StylesChild", required: false)
}

@* ── Mobile sidebar toggle button (injected into page top) ── *@
<div class="d-lg-none mb-3">
    <button class="btn btn-sm btn-outline-secondary sidebar-toggle-btn"
            type="button" data-bs-toggle="offcanvas" data-bs-target="#mobileSidebar">
        <i class="fa fa-bars me-1"></i> Menu
    </button>
</div>

@* ── Main layout ── *@
<div class="file-layout">

    @* ── Desktop Sidebar ── *@
    <aside class="file-sidebar">
        @await Html.PartialAsync("_SidebarContent", new ViewDataDictionary(ViewData)
        {
            { "userLabels",  userLabels  },
            { "departments", departments },
            { "currentId",   currentId   },
            { "currentController", currentController }
        })
    </aside>

    @* ── Main content ── *@
    <div class="file-main">
        @RenderBody()
    </div>
</div>

@* ── Off-canvas sidebar (mobile) ── *@
<div class="offcanvas offcanvas-start" tabindex="-1" id="mobileSidebar" aria-labelledby="mobileSidebarLabel"
     style="width:260px;">
    <div class="offcanvas-header">
        <h6 class="offcanvas-title fw-bold" id="mobileSidebarLabel">
            <i class="fa fa-layer-group me-2 text-primary"></i> FileHubOrg
        </h6>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body p-2">
        @await Html.PartialAsync("_SidebarContent", new ViewDataDictionary(ViewData)
        {
            { "userLabels",  userLabels  },
            { "departments", departments },
            { "currentId",   currentId   },
            { "currentController", currentController }
        })
    </div>
</div>

@section Scripts {
<script>
    function requestDownload(fileId) {
        fetch('/File/GenerateDownloadToken', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(fileId)
        })
        .then(function(r) {
            if (!r.ok) throw new Error('HTTP ' + r.status);
            return r.json();
        })
        .then(function(data) {
            if (data.downloadUrl) {
                var a = document.createElement('a');
                a.href = data.downloadUrl;
                a.style.display = 'none';
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
            } else {
                alert('Could not generate a download link.');
            }
        })
        .catch(function(err) {
            console.error('Download error:', err);
            alert('An error occurred while downloading. Please try again.');
        });
    }
</script>

    @await RenderSectionAsync("ScriptsChild", required: false)
}
