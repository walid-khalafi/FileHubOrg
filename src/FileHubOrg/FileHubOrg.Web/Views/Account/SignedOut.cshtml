@{
    ViewData["Title"] = "Signed Out";
}

@section Styles {
    <link rel="stylesheet" href="~/css/account-views.css" />
}

<section style="padding-top: 100px; padding-bottom:100px;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="signout-card">
                    <div class="signout-icon">
                        <i class="bi bi-box-arrow-right"></i>
                    </div>
                    <h2>@ViewData["Title"]</h2>
                    <p>You have successfully signed out of your account. Thank you for using our cargo management system!</p>
                    
                    <div class="btn-group">
                        <a href="@Url.Action("Login", "Account")" class="btn-login">
                            <i class="bi bi-box-arrow-in-right"></i> Sign In Again
                        </a>
                        <a href="/" class="btn-home">
                            <i class="bi bi-house"></i> Go Home
                        </a>
                    </div>

                    <div class="info-box">
                        <h6><i class="bi bi-shield-check"></i> Security Reminder</h6>
                        <p>For your security, always remember to sign out when using shared or public computers. Close all browser windows to complete the sign-out process.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const card = document.querySelector('.signout-card');
            if (card) {
                card.style.opacity = '0';
                card.style.transform = 'translateY(20px)';
                setTimeout(() => {
                    card.style.transition = 'all 0.5s ease';
                    card.style.opacity = '1';
                    card.style.transform = 'translateY(0)';
                }, 100);
            }
        });
    </script>
}
