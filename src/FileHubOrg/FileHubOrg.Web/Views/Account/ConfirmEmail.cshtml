@{
    ViewData["Title"] = "Email Confirmed";
}

@section Styles {
    <link rel="stylesheet" href="~/css/account-views.css" />
}

<section style="padding-top: 100px; padding-bottom:100px;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="confirmation-card">
                    <div class="confirmation-icon">
                        <i class="bi bi-patch-check-fill"></i>
                    </div>
                    <h2>@ViewData["Title"]</h2>
                    <p>Thank you for confirming your email address! Your account is now fully activated and ready to use.</p>
                    
                    <a href="@Url.Action("Login", "Account")" class="btn-login">
                        <i class="bi bi-box-arrow-in-right"></i> Login to Your Account
                    </a>

                    <div class="welcome-box">
                        <h6><i class="bi bi-stars"></i> What's Next?</h6>
                        <ul>
                            <li>Log in with your credentials</li>
                            <li>Complete your profile setup</li>
                            <li>Explore the dashboard features</li>
                            <li>Start managing your cargo operations</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const card = document.querySelector('.confirmation-card');
            if (card) {
                card.style.opacity = '0';
                card.style.transform = 'translateY(20px)';
                setTimeout(() => {
                    card.style.transition = 'all 0.5s ease';
                    card.style.opacity = '1';
                    card.style.transform = 'translateY(0)';
                }, 100);
            }
        });
    </script>
}
