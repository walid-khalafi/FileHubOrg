@model FileHubOrg.Web.Models.DepartmentViewModels.IndexViewModel
@{
    Layout = "_LayoutFile";
    ViewData["Title"] = "Departments";
    int index = 0;
}

<div class="container py-4">
    <div class="row">
        <table class="table table-responsive table-hover table-striped">
            <thead>
                <tr>
                    <th width="50">#</th>
                    <th>Department Name</th>
                 
                    <th width="100">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach(var department in Model.Departments)
                {
                    index++;
                    <tr>
                        <td>@index</td>
                        <td>@department.Name</td>
                        <td><a asp-action="Users" asp-route-id="@department.Id" class="btn btn-sm btn-primary"><i class="fa fa-arrow-alt-circle-right text-white"></i></a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>