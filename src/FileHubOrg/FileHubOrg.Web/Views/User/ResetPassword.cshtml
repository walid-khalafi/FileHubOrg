@model FileHubOrg.Web.Models.UserViewModels.ResetUserPasswordViewModel
@{
    Layout = "_LayoutFile";
    ViewData["Title"] = "Reset Password";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="h4 fw-bold mb-1">Reset Password</h1>
        <p class="text-muted small mb-0">Set a new password for the selected user.</p>
    </div>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary rounded-pill px-3">
        <i class="fa fa-arrow-left me-1"></i> Back to users
    </a>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-4">
        <form asp-action="ResetPassword" method="post" novalidate>
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none" role="alert"></div>

            <input asp-for="UserId" type="hidden" />

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" readonly />
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" type="password" placeholder="New password" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label"></label>
                <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="Confirm new password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <div class="d-flex justify-content-end">
                <button type="submit" class="btn btn-primary rounded-pill px-4">
                    <i class="fa fa-key me-2"></i> Reset Password
                </button>
            </div>
        </form>
    </div>
</div>

@section ScriptsChild {
    <script>
        document.querySelectorAll('input').forEach(function (input) {
            input.addEventListener('input', function () {
                var error = this.parentElement.querySelector('.text-danger');
                if (error) { error.textContent = ''; }
            });
        });
    </script>
}
