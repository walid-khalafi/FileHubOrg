@model FileHubOrg.Web.Models.UserViewModels.UserAuditLogViewModel
@{
    Layout = "_LayoutFile";
    ViewData["Title"] = $"User Audit — {Model.FullName}";
}

<style>
    .audit-section {
        border-radius: 14px;
        background: #fff;
        box-shadow: 0 1px 4px rgba(0,0,0,.06);
        overflow: hidden;
    }

    .audit-section .card-header {
        background: transparent;
        border-bottom: 1px solid #f3f4f6;
        padding: .9rem 1.25rem;
        font-weight: 600;
        font-size: .875rem;
    }

    .audit-table td, .audit-table th {
        vertical-align: middle;
        font-size: .875rem;
    }

    .mono {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    }
</style>

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb bg-light px-3 py-2 rounded small mb-0">
        <li class="breadcrumb-item">
            <a asp-action="Index" class="text-decoration-none">
                <i class="fa fa-users-cog me-1"></i> Users
            </a>
        </li>
        <li class="breadcrumb-item active">Audit</li>
    </ol>
</nav>

<div class="d-flex align-items-center gap-3 mb-4 flex-wrap">
    <div style="width:44px;height:44px;border-radius:11px;background:#ede9fe;
                display:flex;align-items:center;justify-content:center;color:#4f46e5;font-size:1.2rem;">
        <i class="fa fa-shield-halved"></i>
    </div>
    <div class="flex-grow-1">
        <h1 class="h4 fw-bold mb-0">User Audit</h1>
        <p class="text-muted small mb-0">@Model.Email</p>
    </div>
</div>

<div class="row g-3">
    <div class="col-12">
        <div class="audit-section">
            <div class="card-header">
                <i class="fa fa-upload me-2 text-muted"></i> Upload logs
            </div>
            <div class="card-body p-0">
                @if (Model.UploadLogs != null && Model.UploadLogs.Any())
                {
                    <div class="table-responsive">
                        <table class="table audit-table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th style="width:180px;">Time (UTC)</th>
                                    <th>File</th>
                                    <th style="width:200px;">Actor</th>
                                    <th style="width:200px;">IP</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.UploadLogs)
                                {
                                    <tr>
                                        <td>@(item.CreatedAt?.ToString("g") ?? "—")</td>
                                        <td>
                                            @if (item.FileId.HasValue)
                                            {
                                                <div class="fw-semibold">@item.FileName</div>
                                                <div class="small text-muted mono">@item.FileId.Value</div>
                                            }
                                            else
                                            {
                                                <div class="fw-semibold">@item.FileName</div>
                                            }
                                        </td>
                                        <td>
                                            <div class="fw-semibold">@item.ActorFullName</div>
                                            <div class="small text-muted mono">@item.ActorUserId</div>
                                        </td>
                                        <td class="mono">@item.IpAddress</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="p-4 text-muted">
                        <i class="fa fa-info-circle me-2"></i>No upload records found.
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="audit-section">
            <div class="card-header">
                <i class="fa fa-share-alt me-2 text-muted"></i> Share logs
            </div>
            <div class="card-body p-0">
                @if (Model.ShareLogs != null && Model.ShareLogs.Any())
                {
                    <div class="table-responsive">
                        <table class="table audit-table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th style="width:180px;">Time (UTC)</th>
                                    <th>File</th>
                                    <th style="width:200px;">Sharer</th>
                                    <th style="width:200px;">Shared to</th>
                                    <th style="width:200px;">IP</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.ShareLogs)
                                {
                                    <tr>
                                        <td>@(item.CreatedAt?.ToString("g") ?? "—")</td>
                                        <td>
                                            @if (item.FileId.HasValue)
                                            {
                                                <div class="fw-semibold">@item.FileName</div>
                                                <div class="small text-muted mono">@item.FileId.Value</div>
                                            }
                                            else
                                            {
                                                <div class="fw-semibold">@item.FileName</div>
                                            }
                                        </td>
                                        <td>
                                            <div class="fw-semibold">@item.ActorFullName</div>
                                            <div class="small text-muted mono">@item.ActorUserId</div>
                                        </td>
                                        <td>
                                            <div class="fw-semibold">@item.SharedToFullName</div>
                                            <div class="small text-muted mono">@item.SharedToUserId</div>
                                        </td>
                                        <td class="mono">@item.IpAddress</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="p-4 text-muted">
                        <i class="fa fa-info-circle me-2"></i>No share records found.
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="mt-4 d-flex gap-2 justify-content-end">
    <a asp-action="Index" class="btn btn-secondary rounded-pill px-4">
        <i class="fa fa-arrow-left me-1"></i> Back
    </a>
</div>

