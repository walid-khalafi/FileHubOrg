@model FileHubOrg.Web.Models.UserViewModels.UserStorageReportViewModel
@{
    Layout = "_LayoutFile";
    ViewData["Title"] = "User Storage Report";

    string Initials(string name) => string.Concat(
        name.Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Take(2).Select(w => w[0].ToString().ToUpper()));

    var palette = new[] {
        ("#ede9fe","#4f46e5"), ("#dcfce7","#16a34a"), ("#fef3c7","#d97706"),
        ("#fee2e2","#dc2626"), ("#e0f2fe","#0284c7"), ("#fce7f3","#db2777")
    };
}

<style>
    #storageTable td { vertical-align: middle; }

    .user-avatar-sm {
        width: 36px; height: 36px; border-radius: 50%;
        font-size: .78rem; font-weight: 700;
        display: inline-flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }

    .storage-bar {
        height: 10px;
        border-radius: 999px;
        overflow: hidden;
        background: #e5e7eb;
    }

    .storage-fill {
        height: 100%;
        background: linear-gradient(90deg, #10b981, #4f46e5);
        width: 0%;
    }

    .storage-row-unlimited .storage-fill {
        background: #9ca3af;
    }
</style>

<div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
    <div class="d-flex align-items-center gap-3">
        <div style="width:44px;height:44px;border-radius:11px;background:#ede9fe;
                    display:flex;align-items:center;justify-content:center;color:#4f46e5;font-size:1.2rem;">
            <i class="fa fa-hdd"></i>
        </div>
        <div>
            <h1 class="h4 fw-bold mb-0">User Storage Report</h1>
            <p class="text-muted small mb-0">Used storage per user with progress</p>
        </div>
    </div>

    <a asp-action="Index" class="btn btn-sm btn-secondary rounded-pill px-3">
        <i class="fa fa-arrow-left me-1"></i> Back to Users
    </a>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
        <div class="table-responsive" style="min-height:520px;">
            <table id="storageTable" class="table table-hover align-middle mb-0">
                <thead class="table-light">
                <tr>
                    <th style="width:48px;"></th>
                    <th>User</th>
                    <th>Department</th>
                    <th>Used</th>
                    <th>Limit</th>
                    <th>Usage</th>
                </tr>
                </thead>
                <tbody>
                @for (int i = 0; i < Model.Rows.Count; i++)
                {
                    var row = Model.Rows[i];
                    var (bg, fg) = palette[i % palette.Length];

                    var percentText = row.IsUnlimited ? "Unlimited" : $"{Math.Round(row.UsagePercentage, 2)}%";
                    var barPercent = row.IsUnlimited ? 0 : Math.Min(row.UsagePercentage, 100);

                    <tr class="storage-row @(row.IsUnlimited ? "storage-row-unlimited" : "")">
                        <td class="ps-3">
                            <div class="user-avatar-sm" style="background:@bg; color:@fg;">@Initials(row.User.FullName.Length > 0 ? row.User.FullName : row.User.Email ?? "?")</div>
                        </td>
                        <td>
                            <div class="fw-semibold small">@row.User.FullName</div>
                            <div class="small text-muted">@row.User.Email</div>
                        </td>
                        <td>
                            <span class="dept-badge @(row.DepartmentName == "—" ? "none" : "")">@row.DepartmentName</span>
                        </td>
                        <td>
                            <span class="fw-semibold">@Math.Round(row.UsedMb, 2) MB</span>
                        </td>
                        <td>
                            @if (row.IsUnlimited)
                            {
                                <span class="badge bg-secondary">Unlimited</span>
                            }
                            else
                            {
                                <span class="badge bg-light text-dark border">@row.LimitMb?.ToString("0.##") MB</span>
                            }
                        </td>
                        <td style="min-width:220px;">
                            <div class="d-flex align-items-center gap-2">
                                <div class="flex-grow-1">
                                    <div class="storage-bar" aria-label="Storage usage">
                                        <div class="storage-fill" style="width:@(barPercent)%;"></div>
                                    </div>
                                </div>
                                <div class="small text-muted" style="width:90px; text-align:right;">
                                    @percentText
                                </div>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>

            @if (!Model.Rows.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="fa fa-hdd fa-2x mb-2 d-block" style="opacity:.2;"></i>
                    <span class="small">No users found.</span>
                </div>
            }
        </div>
    </div>
</div>

