@*
    Privacy.cshtml: This view displays the website's privacy policy.
    It inherits from the main layout (_Layout.cshtml) and provides a clear,
    well-structured presentation of the privacy policy information.
*@
@{
    // Set the page title, which will be displayed in the browser tab/window.
    ViewData["Title"] = "Privacy Policy";
}

@* 
    This section can be used to inject page-specific CSS if needed, 
    though for a simple policy page, it might not be necessary.
    It renders into the @RenderSection("Styles", ...) in the main layout.
*@
@section Styles {
    <style>
        /* Optional: Styles specifically for the privacy policy page */
        .privacy-policy-container {
            line-height: 1.7; /* Improve readability */
            font-size: 1.1rem; /* Slightly larger font size */
            max-width: 900px; /* Constrain width for better readability on wide screens */
            margin: 2rem auto; /* Center the content */
            padding: 2rem 1.5rem; /* Padding around the content */
            background-color: #ffffff; /* White background for the card */
            border: 1px solid #dee2e6; /* Light border */
            border-radius: 0.75rem; /* Rounded corners */
            box-shadow: 0 0.25rem 0.75rem rgba(0,0,0,0.08); /* Subtle shadow */
        }

            .privacy-policy-container h1 {
                color: #0d6efd; /* Bootstrap primary color for headings */
                margin-bottom: 1.5rem;
                border-bottom: 2px solid #0d6efd;
                padding-bottom: 0.5rem;
            }

            .privacy-policy-container h2 {
                color: #198754; /* Bootstrap success color for subheadings */
                margin-top: 2rem;
                margin-bottom: 1rem;
            }

            .privacy-policy-container p, .privacy-policy-container ul, .privacy-policy-container ol {
                margin-bottom: 1rem;
            }

            .privacy-policy-container ul, .privacy-policy-container ol {
                padding-left: 2.5rem; /* Indentation for lists */
            }

            .privacy-policy-container li {
                margin-bottom: 0.75rem; /* Spacing between list items */
            }
            /* Style for links within the policy */
            .privacy-policy-container a {
                color: #0d6efd; /* Bootstrap primary color for links */
                text-decoration: underline;
            }

                .privacy-policy-container a:hover {
                    text-decoration: none; /* Remove underline on hover */
                }
    </style>
}

@* --- Main Content Area for Privacy Policy --- *@
<div class="privacy-policy-container">
    @* Main Title of the Page *@
    <h1>@ViewData["Title"]</h1>

    @* Introduction Section *@
    <p>
        Welcome to FileHubOrg. Your privacy is important to us. This Privacy Policy explains how FileHubOrg ("we", "us", or "our") collects, uses, and discloses your personal information when you use our website and services (the "Service").
    </p>

    @* Data Collection Section *@
    <h2>Information We Collect</h2>
    <p>We may collect the following types of information:</p>
    <ul>
        <li>
            <strong>Personal Information:</strong> This includes information you provide when you register, such as your name, email address, and potentially your department. We may also collect information about the files you upload and manage.
        </li>
        <li>
            <strong>Usage Data:</strong> Information about how you interact with the Service, such as the features you use, files accessed, and the time/date of your activities.
        </li>
        <li>
            <strong>Technical Information:</strong> Such as your IP address, browser type, operating system, and device information, collected automatically to improve service performance and security.
        </li>
    </ul>

    @* How We Use Your Information Section *@
    <h2>How We Use Your Information</h2>
    <p>We use the collected information for the following purposes:</p>
    <ul>
        <li>To provide and maintain the Service.</li>
        <li>To improve, personalize, and expand our Service.</li>
        <li>To understand how you use our Service.</li>
        <li>To develop new products, services, and features.</li>
        <li>To communicate with you, either directly or through one of our partners, for customer service, to provide updates and other information relating to the Service, and for marketing and promotional purposes.</li>
        <li>To detect and prevent fraud, and to enhance security.</li>
    </ul>

    @* Data Sharing and Disclosure Section *@
    <h2>Sharing and Disclosure of Your Information</h2>
    <p>We do not sell or rent your personal information to third parties. We may share your information in the following circumstances:</p>
    <ul>
        <li><strong>With Your Consent:</strong> We may share information with your consent or at your direction.</li>
        <li><strong>For File Sharing:</strong> When you share a file with other users within your organization via the Service, your username or identifier may be associated with that shared file.</li>
        <li><strong>Service Providers:</strong> We may engage third-party companies and individuals to facilitate our Service, to provide the Service on our behalf, to perform Service-related services, or to assist us in analyzing how our Service is used. These third parties have access to your personal information only to perform these tasks on our behalf and are obligated not to disclose or use it for any other purpose.</li>
        <li><strong>Legal Requirements:</strong> We may disclose your information if required to do so by law or in response to valid requests by public authorities.</li>
    </ul>

    @* Security Section *@
    <h2>Data Security</h2>
    <p>
        We take reasonable measures to help protect information about you from loss, theft, misuse, unauthorized access, disclosure, alteration, and destruction. However, please be aware that no method of transmission over the Internet or method of electronic storage is 100% secure.
    </p>

    @* Your Choices Section *@
    <h2>Your Choices</h2>
    <p>You may have choices regarding the information you provide to us. You can typically manage your account settings and preferences.</p>

    @* Contact Us Section *@
    <h2>Contact Us</h2>
    <p>
        If you have any questions about this Privacy Policy, please contact us at:
        <br />
        Email: <a href="mailto:support@filehuborg.com">support@filehuborg.com</a>
    </p>

    @* Disclaimer/Effective Date *@
    <p class="text-muted small mt-4">
        Effective Date: October 26, 2023. This policy may be updated from time to time. Please review it periodically.
    </p>
</div>

@* Section for page-specific scripts, if any are needed. *@
@section Scripts {
    @* Example: If you needed a script for an interactive element on this page *@
    @* <script> console.log('Privacy Policy page scripts loaded.'); </script> *@
}