@using Microsoft.AspNetCore.Identity
@using FileHubOrg.Domain.Entities.User
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject FileHubOrg.Application.Interfaces.IFileService fileService
@inject FileHubOrg.Application.Interfaces.IApplicationUserService userService
@inject FileHubOrg.Application.Interfaces.ILabelService labelService
@inject FileHubOrg.Application.Interfaces.IDepartmentService departmentService

@{
    ViewData["Title"] = "Dashboard";
}

@* ── Guest landing ── *@
@if (!SignInManager.IsSignedIn(User))
{
    <div class="row align-items-center justify-content-center" style="min-height:70vh;">
        <div class="col-12 col-lg-6 text-center text-lg-start">
            <span class="badge rounded-pill px-3 py-2 mb-3 d-inline-block"
                  style="background:#ede9fe; color:#4f46e5;">
                Secure · Organised · Collaborative
            </span>
            <h1 class="display-4 fw-bold mb-3">Manage your files<br>with confidence.</h1>
            <p class="lead text-muted mb-4">
                Upload, label, and share documents with your team — all in one place.
            </p>
            <div class="d-flex gap-3 flex-wrap">
                <a asp-controller="Account" asp-action="Login"
                   class="btn btn-primary btn-lg rounded-pill px-4">
                    <i class="fa fa-sign-in-alt me-2"></i> Sign In
                </a>
            </div>
        </div>
        <div class="col-12 col-lg-6 d-none d-lg-flex justify-content-center">
            <i class="fa fa-layer-group" style="font-size:12rem; color:#4f46e5; opacity:.1;"></i>
        </div>
    </div>
    return;
}


@* ── Authenticated dashboard ── *@
@{
    var currentUser = await UserManager.GetUserAsync(User);
    var userId      = currentUser!.Id;
    var allFiles    = await fileService.GetFilesAsync(userId);
    var uploadStats = await userService.GetUserUploadStatsAsync(userId);
    var labels      = await labelService.GetLabelsAsync(userId);
    var departments = await departmentService.GetDepartmentsAsync();
    var recentFiles = allFiles.OrderByDescending(f => f.CreatedAt).Take(5).ToList();
    var totalSize   = allFiles.Sum(f => f.Size);
    var uploadLimit = uploadStats.limitBytes;
    var uploadUsagePercent = uploadLimit.HasValue && uploadLimit.Value > 0
        ? Math.Min(uploadStats.totalSizeBytes * 100.0 / uploadLimit.Value, 100.0)
        : 0;
    var remainingBytes = uploadLimit.HasValue
        ? Math.Max(uploadLimit.Value - uploadStats.totalSizeBytes, 0)
        : 0;

    var initials = string.Concat(
        currentUser.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Take(2).Select(w => w[0].ToString().ToUpper()));

    string FormatSize(long bytes)
    {
        if (bytes >= 1_073_741_824) return $"{bytes / 1_073_741_824.0:F1} GB";
        if (bytes >= 1_048_576)     return $"{bytes / 1_048_576.0:F1} MB";
        if (bytes >= 1_024)         return $"{bytes / 1_024.0:F0} KB";
        return $"{bytes} B";
    }

    string FileIcon(string? name)
    {
        var ext = System.IO.Path.GetExtension(name)?.ToLowerInvariant();
        return ext switch
        {
            ".pdf"                                 => "fa-file-pdf text-danger",
            ".doc" or ".docx"                      => "fa-file-word text-primary",
            ".xls" or ".xlsx"                      => "fa-file-excel text-success",
            ".jpg" or ".jpeg" or ".png" or ".gif"
                or ".webp"                         => "fa-file-image text-warning",
            ".zip" or ".rar" or ".7z"              => "fa-file-archive text-muted",
            ".txt"                                 => "fa-file-alt text-dark",
            _                                      => "fa-file text-secondary"
        };
    }
}

<style>
    .stat-card {
        border: none; border-radius: 14px; padding: 1.3rem 1.4rem;
        background: #fff; box-shadow: 0 1px 4px rgba(0,0,0,.06);
        transition: transform .15s, box-shadow .15s;
    }
    .stat-card:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,.09); }
    .stat-icon {
        width: 44px; height: 44px; border-radius: 11px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.1rem; flex-shrink: 0;
    }
    .stat-value { font-size: 1.7rem; font-weight: 700; line-height: 1.1; }
    .stat-label { font-size: .78rem; color: #9ca3af; font-weight: 500; margin-top: .15rem; }

    .dash-card {
        border: none; border-radius: 14px; background: #fff;
        box-shadow: 0 1px 4px rgba(0,0,0,.06);
    }
    .dash-card .card-header {
        background: transparent; border-bottom: 1px solid #f3f4f6;
        padding: .9rem 1.2rem .75rem; font-weight: 600; font-size: .875rem;
    }
    .dash-card .card-body { padding: 1rem 1.2rem; }

    .file-row {
        display: flex; align-items: center; gap: .8rem;
        padding: .55rem .4rem; border-radius: 8px;
        transition: background .12s; text-decoration: none; color: inherit;
    }
    .file-row:hover { background: #f9fafb; }
    .file-row .fn { font-size: .875rem; font-weight: 500; white-space: nowrap;
                    overflow: hidden; text-overflow: ellipsis; max-width: 180px; }
    .file-row .fm { font-size: .72rem; color: #9ca3af; }

    .quick-action {
        display: flex; flex-direction: column; align-items: center;
        justify-content: center; gap: .45rem; padding: 1rem .5rem;
        border-radius: 12px; border: 1.5px solid #e9ecef; background: #fff;
        font-size: .78rem; font-weight: 600; color: #374151;
        text-decoration: none; transition: border-color .15s, background .15s, color .15s;
        cursor: pointer;
    }
    .quick-action:hover { border-color: #4f46e5; background: #f5f3ff; color: #4f46e5; }
    .qa-icon {
        width: 38px; height: 38px; border-radius: 10px;
        display: flex; align-items: center; justify-content: center; font-size: 1rem;
    }

    .dash-avatar {
        width: 52px; height: 52px; border-radius: 50%;
        background: #4f46e5; color: #fff; font-size: 1.2rem; font-weight: 700;
        display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }

    .label-pill {
        display: inline-flex; align-items: center; gap: .35rem;
        padding: .28rem .7rem; border-radius: 20px; background: #f3f4f6;
        font-size: .78rem; font-weight: 500; color: #374151;
        text-decoration: none; transition: background .12s, color .12s;
    }
    .label-pill:hover { background: #ede9fe; color: #4f46e5; }
    .label-pill .lp-n {
        background: #e5e7eb; border-radius: 20px;
        padding: 0 5px; font-size: .68rem; font-weight: 700;
    }
</style>

@* ── Greeting ── *@
<div class="d-flex flex-wrap align-items-center justify-content-between mb-4 gap-3">
    <div class="d-flex align-items-center gap-3">
        <div class="dash-avatar">@initials</div>
        <div>
            <h1 class="h4 fw-bold mb-0">
                Good @(DateTime.Now.Hour < 12 ? "morning" : DateTime.Now.Hour < 17 ? "afternoon" : "evening"),
                @currentUser.FirstName!
            </h1>
            <p class="text-muted small mb-0">
                @DateTime.Now.ToString("dddd, MMMM d")
                @if (currentUser.Department != null)
                {
                    <span>&nbsp;·&nbsp;<i class="fa fa-sitemap me-1"></i>@currentUser.Department.Name</span>
                }
            </p>
        </div>
    </div>
    <a asp-controller="File" asp-action="Index" class="btn btn-primary rounded-pill px-4">
        <i class="fa fa-folder-open me-2"></i> Open Files
    </a>
</div>

@* ── Stat cards ── *@
<div class="row g-3 mb-4">
    <div class="col-6 col-lg-2">
        <div class="stat-card d-flex align-items-center gap-3">
            <div class="stat-icon" style="background:#ede9fe;">
                <i class="fa fa-upload" style="color:#4f46e5;"></i>
            </div>
            <div>
                <div class="stat-value">@allFiles.Count</div>
                <div class="stat-label">Uploaded Files</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-2">
        <div class="stat-card d-flex align-items-center gap-3">
            <div class="stat-icon" style="background:#fef3c7;">
                <i class="fa fa-tag" style="color:#d97706;"></i>
            </div>
            <div>
                <div class="stat-value">@labels.Count</div>
                <div class="stat-label">Labels</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-2">
        <div class="stat-card d-flex align-items-center gap-3">
            <div class="stat-icon" style="background:#dcfce7;">
                <i class="fa fa-hdd" style="color:#16a34a;"></i>
            </div>
            <div>
                <div class="stat-value" >@FormatSize(totalSize)</div>
                <div class="stat-label">Storage Used</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-2">
        <div class="stat-card d-flex align-items-center gap-3">
            <div class="stat-icon" style="background:#fee2e2;">
                <i class="fa fa-sitemap" style="color:#dc2626;"></i>
            </div>
            <div>
                <div class="stat-value">@departments.Count</div>
                <div class="stat-label">Departments</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-2">
        <div class="stat-card d-flex align-items-center gap-3">
            <div class="stat-icon" style="background:#fce7f3;">
                <i class="fa fa-balance-scale" style="color:#be185d;"></i>
            </div>
            <div>
                <div class="stat-value">@(uploadLimit.HasValue? FormatSize(uploadLimit.Value) : "∞")</div>
                <div class="stat-label">Upload Limit</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-2">
        <div class="stat-card d-flex align-items-center gap-3">
            <div class="stat-icon" style="background:#fef3c7;">
                <i class="fa fa-hourglass-half" style="color:#d97706;"></i>
            </div>
            <div>
                <div class="stat-value">@(uploadLimit.HasValue? FormatSize(remainingBytes) : "∞")</div>
                <div class="stat-label">Remaining</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
  
    <div class="col-12">
        <div class="dash-card">
            <div class="card-body">
                <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-3">
                    <div>
                        <h2 class="h5 mb-1">Upload Statistics</h2>
                        <p class="text-muted mb-0">Track file count, storage usage, and your upload quota.</p>
                    </div>
                    <div class="text-end">
                        <div class="fw-bold">@FormatSize(uploadStats.totalSizeBytes) used</div>
                        <small class="text-muted">of @(uploadLimit.HasValue ? FormatSize(uploadLimit.Value) : "Unlimited")</small>
                    </div>
                </div>

                <div class="mb-3">
                    <div class="progress" style="height: 12px; border-radius: 999px; overflow:hidden; background:#e5e7eb;">
                        <div class="progress-bar bg-primary"
                             role="progressbar"
                             style="width:@(uploadLimit.HasValue ? $"{uploadUsagePercent:F0}%" : "100%") ; min-width: 2rem;"
                             aria-valuenow="@(uploadLimit.HasValue ? uploadUsagePercent : 100)"
                             aria-valuemin="0"
                             aria-valuemax="100">
                            @(uploadLimit.HasValue ? $"{uploadUsagePercent:F0}%" : "Unlimited")
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@* ── Main grid ── *@
<div class="row g-3">

    @* Recent Files *@
    <div class="col-12 col-lg-5">
        <div class="dash-card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="fa fa-clock me-2 text-muted"></i>Recent Files</span>
                <a asp-controller="File" asp-action="Index"
                   class="btn btn-sm btn-outline-secondary rounded-pill px-3"
                   style="font-size:.72rem;">View All</a>
            </div>
            <div class="card-body">
                @if (recentFiles.Any())
                {
                    foreach (var file in recentFiles)
                    {
                        <a href="@Url.Action("Index", "File")" class="file-row">
                            <i class="fa @FileIcon(file.OrginalName)"
                               style="width:20px; text-align:center; flex-shrink:0;"></i>
                            <div class="flex-grow-1 overflow-hidden">
                                <div class="fn">@file.OrginalName</div>
                                <div class="fm">
                                    @FormatSize(file.Size) &nbsp;·&nbsp;
                                    @file.CreatedAt.ToString("MMM d, yyyy")
                                </div>
                            </div>
                            @if (file.Label != null)
                            {
                                <span class="badge rounded-pill"
                                      style="background:#ede9fe; color:#4f46e5; font-size:.68rem;">
                                    @file.Label.Name
                                </span>
                            }
                        </a>
                    }
                }
                else
                {
                    <div class="text-center py-5 text-muted">
                        <i class="fa fa-folder-open fa-2x mb-2 d-block" style="opacity:.25;"></i>
                        <span class="small">No files yet.</span>
                    </div>
                }
            </div>
        </div>
    </div>

    @* Right column *@
    <div class="col-12 col-lg-7 d-flex flex-column gap-3">

        @* Quick Actions *@
        <div class="dash-card">
            <div class="card-header">
                <i class="fa fa-bolt me-2 text-muted"></i>Quick Actions
            </div>
            <div class="card-body">
                <div class="row g-2">
                    <div class="col-6 col-sm-3">
                        <a asp-controller="File" asp-action="Index" class="quick-action w-100">
                            <div class="qa-icon" style="background:#ede9fe;">
                                <i class="fa fa-folder-open" style="color:#4f46e5;"></i>
                            </div>
                            My Files
                        </a>
                    </div>
                    <div class="col-6 col-sm-3">
                        <a href="javascript:;" class="quick-action w-100"
                           data-bs-toggle="modal" data-bs-target="#dashUploadModal">
                            <div class="qa-icon" style="background:#dcfce7;">
                                <i class="fa fa-upload" style="color:#16a34a;"></i>
                            </div>
                            Upload
                        </a>
                    </div>
                    <div class="col-6 col-sm-3">
                        <a href="javascript:;" class="quick-action w-100"
                           data-bs-toggle="modal" data-bs-target="#dashLabelModal">
                            <div class="qa-icon" style="background:#fef3c7;">
                                <i class="fa fa-tag" style="color:#d97706;"></i>
                            </div>
                            New Label
                        </a>
                    </div>
                    <div class="col-6 col-sm-3">
                        <a asp-controller="Department" asp-action="Index" class="quick-action w-100">
                            <div class="qa-icon" style="background:#fee2e2;">
                                <i class="fa fa-sitemap" style="color:#dc2626;"></i>
                            </div>
                            Departments
                        </a>
                    </div>
                </div>
            </div>
        </div>

        @* Labels *@
        <div class="dash-card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="fa fa-tags me-2 text-muted"></i>My Labels</span>
                <span class="badge bg-secondary rounded-pill" style="font-size:.7rem;">@labels.Count</span>
            </div>
            <div class="card-body">
                @if (labels.Any())
                {
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var label in labels)
                        {
                            var count = allFiles.Count(f => f.LabelId == label.Id);
                            <a href="@Url.Action("Index", "File", new { id = label.Id })"
                               class="label-pill">
                                <i class="fa fa-tag" style="font-size:.65rem; color:#4f46e5;"></i>
                                @label.Name
                                <span class="lp-n">@count</span>
                            </a>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-3 text-muted small">
                        No labels yet.
                        <a href="javascript:;" data-bs-toggle="modal" data-bs-target="#dashLabelModal"
                           class="text-primary text-decoration-none ms-1">Create one</a>
                    </div>
                }
            </div>
        </div>

        @* Departments *@
        <div class="dash-card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="fa fa-sitemap me-2 text-muted"></i>Departments</span>
                <span class="badge bg-secondary rounded-pill" style="font-size:.7rem;">@departments.Count</span>
            </div>
            <div class="card-body">
                @if (departments.Any())
                {
                    <div class="row g-2">
                        @foreach (var dept in departments)
                        {
                            <div class="col-12 col-sm-6">
                                <a asp-controller="Department" asp-action="Users"
                                   asp-route-id="@dept.Id"
                                   class="d-flex align-items-center gap-2 p-2 rounded-3 text-decoration-none dept-row">
                                    <div style="width:32px; height:32px; border-radius:8px; background:#e0e7ff;
                                                display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                                        <i class="fa fa-users" style="color:#4f46e5; font-size:.8rem;"></i>
                                    </div>
                                    <div class="overflow-hidden">
                                        <div class="fw-semibold text-dark text-truncate"
                                             style="font-size:.83rem;">@dept.Name</div>
                                        <div class="text-muted" style="font-size:.7rem;">
                                            @dept.Members.Count member(s)
                                        </div>
                                    </div>
                                </a>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-3 text-muted small">No departments available.</div>
                }
            </div>
        </div>

    </div>
</div>


@* ── Upload modal ── *@
<div class="modal fade" id="dashUploadModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <form asp-controller="File" asp-action="UploadFile" method="post"
              enctype="multipart/form-data" class="modal-content"
              style="border-radius:14px; border:none; box-shadow:0 20px 60px rgba(0,0,0,.15);">
            @Html.AntiForgeryToken()
            <div class="modal-header" style="border-bottom:1px solid #f3f4f6;">
                <h5 class="modal-title fw-semibold">
                    <i class="fa fa-upload me-2 text-success"></i>Upload File
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="dashDropZone" class="text-center p-4 mb-3 rounded-3"
                     style="border:2px dashed #ced4da; cursor:pointer; transition:all .2s;"
                     onclick="document.getElementById('dashFileInput').click()"
                     ondragover="event.preventDefault(); this.style.borderColor='#4f46e5'; this.style.background='#f5f3ff';"
                     ondragleave="this.style.borderColor='#ced4da'; this.style.background='';"
                     ondrop="dashHandleDrop(event)">
                    <i class="fa fa-cloud-upload-alt fa-2x text-muted mb-2 d-block"></i>
                    <span class="text-muted small">
                        Drag &amp; drop or <span class="text-primary">browse</span>
                    </span>
                </div>
                <input type="file" id="dashFileInput" name="file" class="d-none"
                       onchange="dashShowFile(this)" required />
                <div id="dashFileInfo" class="alert alert-light py-2 small mb-3" style="display:none;">
                    <i class="fa fa-paperclip me-1"></i><span id="dashFileName"></span>
                </div>
                <label class="form-label small fw-semibold">Label (optional)</label>
                <select name="labelId" class="form-select form-select-sm">
                    <option value="">— No label —</option>
                    @foreach (var label in labels)
                    {
                        <option value="@label.Id">@label.Name</option>
                    }
                </select>
            </div>
            <div class="modal-footer" style="border-top:1px solid #f3f4f6;">
                <button type="submit" class="btn btn-primary rounded-pill px-4">
                    <i class="fa fa-upload me-1"></i> Upload
                </button>
                <button type="button" class="btn btn-secondary rounded-pill px-4"
                        data-bs-dismiss="modal">Cancel</button>
            </div>
        </form>
    </div>
</div>

@* ── New Label modal ── *@
<div class="modal fade" id="dashLabelModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <form asp-controller="File" asp-action="CreateLabel" method="post"
              class="modal-content"
              style="border-radius:14px; border:none; box-shadow:0 20px 60px rgba(0,0,0,.15);">
            @Html.AntiForgeryToken()
            <div class="modal-header" style="border-bottom:1px solid #f3f4f6;">
                <h5 class="modal-title fw-semibold">
                    <i class="fa fa-tag me-2 text-warning"></i>New Label
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <label for="dashLabelName" class="form-label small fw-semibold">Label Name</label>
                <input type="text" id="dashLabelName" name="Name" class="form-control"
                       placeholder="e.g. Invoices, Reports…" required autofocus />
            </div>
            <div class="modal-footer" style="border-top:1px solid #f3f4f6;">
                <button type="submit" class="btn btn-primary rounded-pill px-4">Create</button>
                <button type="button" class="btn btn-secondary rounded-pill px-4"
                        data-bs-dismiss="modal">Cancel</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<style>
    .dept-row { background: #f9fafb; transition: background .12s; }
    .dept-row:hover { background: #f3f4f6; }
</style>
<script>
    function dashHandleDrop(e) {
        e.preventDefault();
        var dz = document.getElementById('dashDropZone');
        dz.style.borderColor = '#ced4da';
        dz.style.background  = '';
        var files = e.dataTransfer.files;
        if (files.length > 0) {
            document.getElementById('dashFileInput').files = files;
            dashShowFile(document.getElementById('dashFileInput'));
        }
    }
    function dashShowFile(input) {
        if (input.files && input.files.length > 0) {
            document.getElementById('dashFileName').textContent = input.files[0].name;
            document.getElementById('dashFileInfo').style.display = '';
        }
    }
</script>
}
