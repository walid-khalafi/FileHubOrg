    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@model FileHubOrg.Web.Models.FileViewModels.UserSharedFiles
@{
    Layout = "_LayoutFile";
    ViewData["Title"] = $"User Shared Files";
}

@functions {
    public string GetFileIconClass(string fileName)
    {
        var ext = System.IO.Path.GetExtension(fileName)?.ToLowerInvariant();
        return ext switch
        {
            ".pdf" => "fa-file-pdf text-danger",
            ".doc" or ".docx" => "fa-file-word text-primary",
            ".xls" or ".xlsx" => "fa-file-excel text-success",
            ".jpg" or ".jpeg" or ".png" or ".gif" => "fa-file-image text-warning",
            ".zip" or ".rar" => "fa-file-archive text-muted",
            ".txt" => "fa-file-alt text-dark",
            _ => "fa-file text-secondary"
        };
    }
}
<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb bg-light px-3 py-2 rounded small">

        <li class="breadcrumb-item active">
            <a href="@Url.Action("Users", "Department", new { id = Model.DepartmentId })" class="text-decoration-none">@Model.DepartmentName</a>
        </li>
        <li class="breadcrumb-item active">
            <a href="@Url.Action("UserSharedFiles", "File", new { id = Model.userId })" class="text-decoration-none"></a>
            @Model.FullName
        </li>
    </ol>
</nav>
<div class="container">
    <div class="row">

        @if (Model.files.Count > 0)
        {
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th></th>
                        <th>File Name</th>
                        <th>Description</th>
                        <th>Label</th>
                        <th>File Size MB</th>
                        <th>Created At</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var file in Model.files)
                    {
                        <tr>

                            <td><i class="fa @GetFileIconClass(file.OrginalName)"></i></td>
                            <td>@file.OrginalName</td>
                            <td>@file.Description</td>
                            <td>@file.Label.Name</td>
                            <td>@file.SizeMB</td>
                            <td>@file.CreatedAt</td>
                            <td>
                                <a class="btn btn-sm" onclick="requestDownload('file.Id')"><i class="fa fa-download me-2"></i> </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="alert alert-light border text-muted text-center p-4 mt-4">
                <i class="fa fa-folder-open me-2 fs-4 text-warning"></i> This user hasn't shared any files with you yet!
            </div>
        }

    </div>
</div>