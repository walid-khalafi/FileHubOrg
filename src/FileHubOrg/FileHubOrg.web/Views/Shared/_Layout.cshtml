@using Microsoft.AspNetCore.Identity
@using FileHubOrg.Domain.Entities.User
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FileHubOrg</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FileHubOrg.web.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/fontawesome-free-6.7.2-web/css/all.min.css" />

    <style>
        /* ── Base ── */
        :root {
            --brand-primary: #4f46e5;
            --brand-primary-dark: #3730a3;
            --sidebar-width: 260px;
            --navbar-height: 60px;
        }

        html, body { height: 100%; }

        body {
            background-color: #f5f6fa;
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* ── Navbar ── */
        .app-navbar {
            height: var(--navbar-height);
            background: #fff;
            border-bottom: 1px solid #e9ecef;
            box-shadow: 0 1px 4px rgba(0,0,0,.06);
            position: sticky;
            top: 0;
            z-index: 1030;
        }

        .navbar-brand-text {
            font-weight: 700;
            font-size: 1.15rem;
            color: var(--brand-primary) !important;
            letter-spacing: -.3px;
        }

        .navbar-brand-text .brand-icon {
            width: 30px; height: 30px;
            background: var(--brand-primary);
            border-radius: 8px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: .85rem;
            margin-right: 8px;
        }

        /* Nav links */
        .app-navbar .nav-link {
            color: #6b7280 !important;
            font-size: .9rem;
            font-weight: 500;
            padding: .4rem .75rem !important;
            border-radius: 6px;
            transition: background .15s, color .15s;
        }

        .app-navbar .nav-link:hover {
            background: #f3f4f6;
            color: #111827 !important;
        }

        .app-navbar .nav-link.active-nav {
            background: #ede9fe;
            color: var(--brand-primary) !important;
        }

        /* User avatar */
        .user-avatar {
            width: 34px; height: 34px;
            border-radius: 50%;
            background: var(--brand-primary);
            color: #fff;
            font-size: .8rem;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        /* Dropdown */
        .user-dropdown .dropdown-menu {
            min-width: 200px;
            border: 1px solid #e9ecef;
            box-shadow: 0 8px 24px rgba(0,0,0,.1);
            border-radius: 10px;
            padding: .5rem;
        }

        .user-dropdown .dropdown-item {
            border-radius: 6px;
            font-size: .875rem;
            padding: .45rem .75rem;
        }

        .user-dropdown .dropdown-item:hover { background: #f3f4f6; }

        .user-dropdown .dropdown-divider { margin: .35rem 0; }

        /* ── Page wrapper ── */
        .page-wrapper {
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .page-content {
            flex: 1;
            padding: 1.5rem 0;
        }

        /* ── Footer ── */
        .app-footer {
            background: #fff;
            border-top: 1px solid #e9ecef;
            padding: .85rem 0;
            font-size: .8rem;
            color: #9ca3af;
        }

        .app-footer a { color: #9ca3af; text-decoration: none; }
        .app-footer a:hover { color: var(--brand-primary); }
    </style>

    @RenderSection("Styles", required: false)
</head>
<body>

@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action     = ViewContext.RouteData.Values["action"]?.ToString();

    string NavClass(string c, string a = "Index") =>
        (controller?.Equals(c, StringComparison.OrdinalIgnoreCase) == true &&
         action?.Equals(a, StringComparison.OrdinalIgnoreCase) == true)
        ? "nav-link active-nav" : "nav-link";
}

@* ── Navbar ── *@
<nav class="navbar navbar-expand-lg app-navbar px-3">
    <div class="container-fluid gap-3">

        @* Brand *@
        <a class="navbar-brand navbar-brand-text d-flex align-items-center me-4 text-decoration-none" 
           asp-controller="Home" asp-action="Index">
            <span class="brand-icon"><i class="fa fa-layer-group"></i></span>
            FileHubOrg
        </a>

        @* Mobile toggler *@
        <button class="navbar-toggler border-0 d-lg-none ms-auto me-2" type="button"
                data-bs-toggle="collapse" data-bs-target="#mainNav"
                aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        @* Nav links *@
        <div class="collapse navbar-collapse" id="mainNav">
            <ul class="navbar-nav me-auto gap-1">
                <li class="nav-item">
                    <a class="@NavClass("Home")" asp-controller="Home" asp-action="Index">
                        <i class="fa fa-home me-1"></i> Home
                    </a>
                </li>
                <li class="nav-item">
                    <a class="@NavClass("File")" asp-controller="File" asp-action="Index">
                        <i class="fa fa-folder-open me-1"></i> Files
                    </a>
                </li>
                <li class="nav-item">
                    <a class="@NavClass("Department")" asp-controller="Department" asp-action="Index">
                        <i class="fa fa-sitemap me-1"></i> Departments
                    </a>
                </li>
                @if (User.IsInRole("Admin"))
                {
                    <li class="nav-item">
                        <a class="@NavClass("User")" asp-controller="User" asp-action="Index">
                            <i class="fa fa-users-cog me-1"></i> Users
                        </a>
                    </li>
                }
            </ul>

            @* Right side *@
            <ul class="navbar-nav ms-auto align-items-center gap-2">
                @if (SignInManager.IsSignedIn(User))
                {
                    var currentUser = await UserManager.GetUserAsync(User);
                    var initials = string.Concat(
                        (currentUser?.FullName ?? "U")
                            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
                            .Take(2)
                            .Select(w => w[0].ToString().ToUpper())
                    );

                    <li class="nav-item dropdown user-dropdown">
                        <a class="nav-link d-flex align-items-center gap-2 pe-0" href="#"
                           role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <span class="user-avatar">@initials</span>
                            <span class="d-none d-md-inline fw-medium text-dark small">@currentUser?.FullName</span>
                            <i class="fa fa-chevron-down text-muted" style="font-size:.65rem;"></i>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end mt-2">
                            <li class="px-3 py-2">
                                <div class="fw-semibold text-dark small">@currentUser?.FullName</div>
                                <div class="text-muted" style="font-size:.75rem;">@currentUser?.Email</div>
                            </li>
                            <li><hr class="dropdown-divider" /></li>
                            <li>
                                <a class="dropdown-item" asp-controller="File" asp-action="Index">
                                    <i class="fa fa-folder me-2 text-muted"></i> My Files
                                </a>
                            </li>
                            <li><hr class="dropdown-divider" /></li>
                            <li>
                                <form asp-controller="Account" asp-action="Logout" method="post">
                                    <button type="submit" class="dropdown-item text-danger">
                                        <i class="fa fa-sign-out-alt me-2"></i> Sign Out
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="btn btn-sm btn-primary rounded-pill px-3"
                           asp-controller="Account" asp-action="Login">
                            <i class="fa fa-sign-in-alt me-1"></i> Sign In
                        </a>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>

@* ── Page content ── *@
<div class="page-wrapper">
    <div class="page-content">
        <div class="container">
            <main role="main">
                @RenderBody()
            </main>
        </div>
    </div>

    @* ── Footer ── *@
    <footer class="app-footer">
        <div class="container d-flex flex-wrap justify-content-between align-items-center">
            <span>&copy; @DateTime.Now.Year FileHubOrg &mdash; Secure File Management</span>
            <a asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
        </div>
    </footer>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
