# Example environment file for deploy/docker/docker-compose.yml
# Copy this file to .env and update values before running docker-compose.

DEFAULT_CONNECTION="Server=db,1433;Database=FileHubDB;User Id=sa;Password=YourStrong@Pass123;TrustServerCertificate=True;MultipleActiveResultSets=True;"
SA_PASSWORD="YourStrong@Pass123"
JWT__SECRET="ReplaceWithASecureJwtSecret"
LDAP__URL="ldap.example.com"
LDAP__BINDCREDENTIALS="ReplaceWithLdapBindPassword"
LDAP__BINDON="CN=admin,OU=Users,DC=example,DC=com"
LDAP__SEARCHBASE="DC=example,DC=com"
LDAP__SEARCHFILTER="(&(objectClass=*)(sAMAccountName={0}))"
